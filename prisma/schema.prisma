// ORYX backend — Prisma schema (canonical source of truth for the database).
// Domain models are added per feature module in Fase 1.x sessions.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis, pgcrypto]
}

// ─── Auth (sessão 1.1) ──────────────────────────────────────────────────────

/// RBAC roles. Single role per user for now (CLAUDE.md §3.6 — refactor to a
/// user_roles join table when a real multi-role scenario lands).
enum Role {
  OPERATOR
  SQUAD_LEADER
  ADMIN
  INSTRUCTOR
}

model User {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String   @unique
  passwordHash  String   @map("password_hash")
  displayName   String   @map("display_name")
  role          Role     @default(OPERATOR)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  refreshTokens RefreshToken[]
  operator      Operator?
  createdEvents Event[]  @relation("EventCreator")

  @@map("users")
}

/// Refresh tokens are stored as sha256(token) so a database leak does not
/// disclose live tokens. Rotation: each /auth/refresh issues a new pair and
/// marks the old row revokedAt = now().
model RefreshToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ─── Operators (sessão 1.3) ─────────────────────────────────────────────────

enum BloodType {
  A_POS
  A_NEG
  B_POS
  B_NEG
  AB_POS
  AB_NEG
  O_POS
  O_NEG
  UNKNOWN
}

enum OperatorStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// ─── Events (sessão 1.4) ────────────────────────────────────────────────────

enum EventStatus {
  DRAFT
  ACTIVE
  ENDED
}

enum EventMode {
  WARFARE
  COMPETITIVE
  CHALLENGER
  SNIPER
  TACTICAL_TRAINING
}

/// Operational event (warfare run, competitive round, training class…).
/// `operationalArea` is a GeoJSON Polygon stored as JSONB. PostGIS index +
/// generated geography column come in session 1.11 (zones) when the first
/// spatial query consumer lands.
model Event {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  description     String?
  mode            EventMode
  status          EventStatus @default(DRAFT)
  operationalArea Json        @map("operational_area")
  startsAt        DateTime?   @map("starts_at") @db.Timestamptz(6)
  endsAt          DateTime?   @map("ends_at") @db.Timestamptz(6)
  createdById     String?     @map("created_by_id") @db.Uuid
  createdAt       DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy       User?       @relation("EventCreator", fields: [createdById], references: [id], onDelete: SetNull)
  teams           Team[]

  @@index([status])
  @@index([mode])
  @@map("events")
}

// ─── Teams / facções (sessão 1.5) ───────────────────────────────────────────

/// Faction within an event — identity carrier (color + emblem) for groups of
/// operators. UNIQUE (event_id, name) keeps faction names per-event unambiguous.
model Team {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId     String   @map("event_id") @db.Uuid
  name        String
  color       String
  emblem      String?
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  squads      Squad[]

  @@unique([eventId, name])
  @@index([eventId])
  @@map("teams")
}

/// Tactical profile for a field operator. One per user (1:1, optional —
/// admin/instructor users have no Operator row).
model Operator {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String         @unique @map("user_id") @db.Uuid
  callsign         String         @unique
  bio              String?
  emergencyContact String?        @map("emergency_contact")
  bloodType        BloodType      @default(UNKNOWN) @map("blood_type")
  status           OperatorStatus @default(ACTIVE)
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  squadMemberships SquadMember[]
  squadsLed        Squad[]        @relation("SquadLeader")

  @@map("operators")
}

// ─── Squads (sessão 1.6) ────────────────────────────────────────────────────

enum SquadStatus {
  ACTIVE
  INACTIVE
  DISBANDED
}

/// Sub-group within a Team. UNIQUE (team_id, name) keeps squad names per-team
/// unambiguous. leaderId is optional and must be a member of the squad — the
/// service enforces that invariant on PATCH and on member removal.
model Squad {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teamId      String        @map("team_id") @db.Uuid
  name        String
  description String?
  leaderId    String?       @map("leader_id") @db.Uuid
  status      SquadStatus   @default(ACTIVE)
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  team        Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  leader      Operator?     @relation("SquadLeader", fields: [leaderId], references: [id], onDelete: SetNull)
  members     SquadMember[]

  @@unique([teamId, name])
  @@index([teamId])
  @@index([leaderId])
  @@map("squads")
}

/// Junction Squad <-> Operator. Hard delete on removal — audit/history of
/// joins/leaves comes when the audit module lands (Fase 4.x).
model SquadMember {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  squadId    String   @map("squad_id") @db.Uuid
  operatorId String   @map("operator_id") @db.Uuid
  joinedAt   DateTime @default(now()) @map("joined_at") @db.Timestamptz(6)
  squad      Squad    @relation(fields: [squadId], references: [id], onDelete: Cascade)
  operator   Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  @@unique([squadId, operatorId])
  @@index([operatorId])
  @@map("squad_members")
}
